# OS / editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Dependencies
node_modules/

# Build and framework output
.next/
.next-verify/
.next-stale-*/
out/
dist/
build/
coverage/
*.tsbuildinfo

# Test and browser automation artifacts
.playwright-cli/
playwright-report/
test-results/
blob-report/
playwright/.cache/

# Public storefront assets must ship with Git-based deployments, even if a
# local editor excludes media files broadly.
!public/catalog-assets/**/*.jpg
!public/catalog-assets/**/*.jpeg
!public/catalog-assets/**/*.png
!public/catalog-assets/**/*.svg
!public/catalog-assets/**/*.webp
!public/shipk-brand/**/*.jpg
!public/shipk-brand/**/*.jpeg
!public/shipk-brand/**/*.png
!public/shipk-brand/**/*.svg
!public/shipk-brand/**/*.webp

# This route intentionally serves /favicon.ico without committing a binary .ico.
!src/app/favicon.ico/
!src/app/favicon.ico/route.ts

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local environment and secrets
.env
.env.*
.env*.local
*.env
*.env.*
!.env.example
!.env*.example
!*.env.example
!*.env*.example
*.pem
*.key
*.p8
*.p12
*.crt
*.cert

# Deployment / platform local metadata
.vercel/
.netlify/

# Supabase local state
supabase/.temp/
supabase/seed.sql

# Internal documentation
docs/

# Agent/runtime local state
.omx/
.codex/
.git-private-backup/
.git-backup/

# Local-only private working areas
private/
private-assets/
admin-temp/
scratch/
